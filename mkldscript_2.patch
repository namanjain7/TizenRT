--- /dev/null
+++ b/build/configs/bk7239n/scripts/xipelf/get_binary_address.py
@@ -0,0 +1,83 @@
+#!/usr/bin/env python
+###########################################################################
+#
+# Copyright 2026 Samsung Electronics All Rights Reserved.
